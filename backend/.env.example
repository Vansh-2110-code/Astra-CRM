# ASTRA CRM SaaS Platform Backend Environment Configuration (Template)

# 🌐 API Gateway Server Config
PORT=5000
NODE_ENV=development

# 🔑 Encryption & Security Secrets
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_key_here

# 🔌 Databases & Cache Connections
# PostgreSQL Production Connection Schema URL
DATABASE_URL="postgresql://username:password@localhost:5432/db_name?schema=public"

# Redis Server connection string for session / IP Whitelist / rate limiting
REDIS_URL="redis://127.0.0.1:6379/0"

# 🖥️ CORS Trusted Client Front-End Domain
FRONTEND_URL="http://localhost:5173"
